# =============================================================================
# Botforge frontend — copy to `.env.local` for local development (Next.js loads it automatically).
# Never commit real secrets. Values below are illustrative only.
# =============================================================================

# --- API ---
# REST base URL including /api (must match Botforge-BE mount path).
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Backend origin without /api: uploads, absolute file URLs, Socket.io host.
NEXT_PUBLIC_BE_URL=http://localhost:8000

# Browser-facing origin of this Next app (OAuth redirects, absolute links).
NEXT_PUBLIC_BASE_URL=https://localhost:3000

# --- Auth ---
# Meta / Facebook app ID for the in-app Facebook login button.
NEXT_PUBLIC_FACEBOOK_APP_ID=0000000000000000

# Firebase Web SDK — must match the Firebase project used by the backend for token verification.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyExampleKeyReplaceMe000000000000000
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# NODE_ENV is normally set by Next.js; only set manually if you know you need to (cookie Secure flag in src/app/api/auth/*).
# NODE_ENV=development

# --- Feature flags ---
# (none — no NEXT_PUBLIC_* feature toggles are read in src/)
